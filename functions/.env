# server/.env

# --- Firebase Admin SDK ---
# Path to your Firebase Admin SDK JSON file (download from Firebase Console > Project settings > Service accounts)
FIREBASE_ADMIN_SDK_PATH="./firebase-admin-sdk.json" # Or the actual path if different

# --- Frontend URL (for CORS) ---
FRONTEND_URL=http://localhost:3000 # For local development
# For Vercel deployment, you'll set this in Vercel's environment variables, e.g., https://your-vercel-app-name.vercel.app

# --- General Server Config ---
PORT=3001 # For local Express server (will be ignored by Firebase Functions)
NODE_ENV=development

# --- Gemini API ---
GEMINI_API_KEY=AIzaSyBWiSQNcVPkrGs2JV-BMsIVdRgtto8e36Y # Your existing key

# --- Twitter API v2 (Academic Access or appropriate tier recommended) ---
# You can have multiple, comma-separated, if you need to rotate them
TWITTER_BEARER_TOKENS="YOUR_TWITTER_BEARER_TOKEN_1,YOUR_TWITTER_BEARER_TOKEN_2"

# --- Telegram ---
# For Telegram Bot API (if you want the bot to listen to groups/channels it's part of)
TELEGRAM_BOT_TOKEN=7807445717:AAHAKxTPZ1DaOgUV1TAd6LOY_tcjPcJ21ME # Your existing key

# For Telegram User API (TDLib - allows your backend to act as a user)
# Get these from my.telegram.org > API development tools
TELEGRAM_API_ID=YOUR_TELEGRAM_API_ID
TELEGRAM_API_HASH=YOUR_TELEGRAM_API_HASH
TELEGRAM_PHONE_NUMBER=YOUR_INTERNATIONAL_PHONE_NUMBER # e.g., +12223334444 (for TDLib first-time auth)

# --- Facebook Graph API ---
# Create an App at developers.facebook.com
FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID
FACEBOOK_APP_SECRET=YOUR_FACEBOOK_APP_SECRET
FACEBOOK_ACCESS_TOKEN=YOUR_FACEBOOK_APP_OR_USER_ACCESS_TOKEN # Needs appropriate permissions (e.g., pages_read_engagement)

# --- Instagram Graph API (requires Facebook App and Business/Creator account) ---
# Often managed through the Facebook Graph API
INSTAGRAM_BUSINESS_ACCOUNT_ID=YOUR_INSTAGRAM_BUSINESS_ACCOUNT_ID
# Access token is usually the same as Facebook's if permissions are granted

# --- Eitaa, Rubika, Bale, Soroush Plus ---
# These platforms might not have official, publicly documented, and easily accessible APIs
# for third-party developers in the same way Twitter or Facebook do.
# You may need to investigate if they offer any developer programs or if community-driven
# libraries exist (which might use unofficial methods and could be unstable).

# Placeholder if you find ways to get API keys/tokens:
EITAA_API_TOKEN=YOUR_EITAA_API_TOKEN_IF_AVAILABLE
RUBIKA_API_TOKEN=YOUR_RUBIKA_API_TOKEN_IF_AVAILABLE
BALE_API_TOKEN=YOUR_BALE_API_TOKEN_IF_AVAILABLE
SOROUSH_PLUS_API_TOKEN=YOUR_SOROUSH_PLUS_API_TOKEN_IF_AVAILABLE

# Note: For platforms like Eitaa, Rubika, etc., if official APIs are not available,
# data gathering often relies on web scraping or unofficial client libraries,
# which can be unreliable, against terms of service, and require frequent maintenance.
# I cannot provide code for such methods. Always prioritize official APIs.
